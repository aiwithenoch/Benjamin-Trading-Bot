# AURUM Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# For Vercel deployment, set these in the Vercel Dashboard > Settings > Environment Variables.

# ─── Deriv API ───────────────────────────────────────────────────────────────
# Get your API token from: https://app.deriv.com/account/api-token
VITE_DERIV_API_TOKEN=your_deriv_api_token_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Anthropic / Claude AI ───────────────────────────────────────────────────
# IMPORTANT: This key is only used in local DEV mode via the Vite proxy.
# In PRODUCTION (Vercel), set ANTHROPIC_API_KEY (no VITE_ prefix) instead.
# Get your key from: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Vercel Only (set in Vercel Dashboard, NOT in .env) ──────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
